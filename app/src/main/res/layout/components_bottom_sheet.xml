<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp">

    <View
        android:id="@+id/view_drag_handle"
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:background="@android:drawable/divider_horizontal_bright"
        android:backgroundTint="?attr/colorOutline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_bottom_sheet_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/gilroy_medium"
        android:text="Dettagli prodotto"
        android:textAlignment="center"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_drag_handle" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/img_detail"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_marginTop="16dp"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_bottom_sheet_title"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Large"
        app:srcCompat="@android:drawable/ic_menu_gallery" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/detail_progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/img_detail"
        app:layout_constraintEnd_toEndOf="@id/img_detail"
        app:layout_constraintStart_toStartOf="@id/img_detail"
        app:layout_constraintTop_toTopOf="@id/img_detail" />

    <TextView
        android:id="@+id/tv_detail_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/gilroy_medium"
        android:text="Nome Prodotto"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/img_detail" />

    <TextView
        android:id="@+id/tv_detail_code"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/gilroy_medium"
        android:text="Codice: XXXXXX"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOutline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_detail_name" />

    <LinearLayout
        android:id="@+id/layout_detail_availability"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_detail_code">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/gilroy_medium"
            android:text="Disponibilità"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOutline" />

        <View
            android:id="@+id/view_detail_availability_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="8dp"
            android:background="@android:drawable/presence_online" />
    </LinearLayout>

    <com.google.android.material.chip.Chip
        android:id="@+id/chip_detail_category"
        style="@style/Widget.Material3.Chip.Assist"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/gilroy_medium"
        android:text="Categoria"
        android:textSize="11sp"
        app:chipCornerRadius="@dimen/card_radius"
        app:chipMinTouchTargetSize="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_detail_availability" />

    <com.google.android.material.chip.Chip
        android:id="@+id/chip_detail_subcategory"
        style="@style/Widget.Material3.Chip.Assist"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:layout_marginStart="6dp"
        android:ellipsize="end"
        android:fontFamily="@font/gilroy_medium"
        android:maxLines="1"
        android:text="Sottocategoria"
        android:textSize="11sp"
        app:chipCornerRadius="@dimen/card_radius"
        app:chipMinTouchTargetSize="0dp"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="@id/chip_detail_category"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/chip_detail_category"
        app:layout_constraintTop_toTopOf="@id/chip_detail_category" />

    <TextView
        android:id="@+id/tv_detail_short_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="@font/gilroy_medium"
        android:text="Descrizione breve..."
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorOutline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chip_detail_category" />

    <TextView
        android:id="@+id/tv_detail_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_detail_short_description" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_detail_download"
        style="@style/Widget.Material3.Button"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/gilroy_medium"
        android:text="Scarica Documenti PDF"
        android:textSize="16sp"
        app:icon="@android:drawable/stat_sys_download"
        app:iconSize="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_detail_short_description" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_detail_web"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/gilroy_medium"
        android:text="Vai alla scheda prodotto completa"
        android:textAllCaps="false"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_detail_download" />

</androidx.constraintlayout.widget.ConstraintLayout>